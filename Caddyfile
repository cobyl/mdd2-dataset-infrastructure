mdd.ibb.waw.pl {
	tls /etc/letsencrypt/live/ibb.waw.pl/fullchain.pem /etc/letsencrypt/live/ibb.waw.pl/privkey.pem

	handle /api* {
		reverse_proxy mdd2-dataset-backend:80
	}

    handle /logs* {
        basicauth {
            admin {$DOZZLE_PASSWORD_HASH}
        }
        reverse_proxy dozzle:8080
    }

	handle {
		reverse_proxy mdd2-dataset-frontend:80
	}
}
